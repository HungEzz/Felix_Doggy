# Server Port
PORT=3000

# Database connection URL (points to PostgreSQL container exposed on localhost:5432)
DATABASE_URL="postgresql://postgres:root@localhost:5432/record_store?schema=public"

# Redis Cache connection URL (points to Redis container exposed on localhost:6379)
REDIS_URL="redis://localhost:6379"

# JWT configuration secret key
JWT_SECRET="your-secret-key-here"

# Google Authentication Client ID
GOOGLE_CLIENT_ID="your-google-client-id-here"

# Cloudinary Storage Configuration for product images
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Resend Mail Configuration (Optional - emails will log to console if not set)
RESEND_API_KEY="re_your_api_key_here"
RESEND_FROM="onboarding@resend.dev"

# DeepSeek AI Chatbot Configuration (Optional - chatbot will use keyword fallback search if not set)
DEEPSEEK_API_KEY=""

# CORS Allowed Origin
CORS_ORIGIN="http://localhost:5173"

# PayOS Payment Configuration
PAYOS_CLIENT_ID="your-payos-client-id"
PAYOS_API_KEY="your-payos-api-key"
PAYOS_CHECKSUM_KEY="your-payos-checksum-key"
FRONTEND_URL="http://localhost:5173"
